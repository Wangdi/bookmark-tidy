{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "types": ["chrome", "node"]
  },
  "include": ["src/**/*", "vite.config.ts", "vitest.config.ts", "scripts/*.ts"],
  "exclude": ["node_modules", "dist"]
}
