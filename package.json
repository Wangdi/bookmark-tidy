{
  "name": "bookmark-tidy",
  "version": "1.0.0",
  "description": "Organize and tidy up your Chrome bookmarks",
  "type": "module",
  "scripts": {
    "dev": "vite build --watch --mode development",
    "build": "vite build && node scripts/build.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "chrome-extension",
    "bookmarks",
    "organization"
  ],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@11.1.0",
  "dependencies": {
    "ml-kmeans": "^7.0.0"
  },
  "devDependencies": {
    "@types/chrome": "^0.1.42",
    "@types/node": "^25.6.2",
    "@vitest/coverage-v8": "^4.1.5",
    "fake-indexeddb": "^6.2.5",
    "typescript": "^6.0.3",
    "vite": "^8.0.11",
    "vitest": "^4.1.5"
  }
}
